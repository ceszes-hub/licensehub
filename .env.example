APP_NAME=LicenseHub Enterprise
APP_VERSION=1.0-dev0
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=
DJANGO_ALLOWED_HOSTS=localhost
CSRF_TRUSTED_ORIGINS=https://localhost
DEBUG=False
POSTGRES_DB=licensehub
POSTGRES_USER=licensehub
POSTGRES_PASSWORD=
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
TIME_ZONE=Europe/Budapest
LANGUAGE_CODE=hu
TLS_SERVER_NAME=localhost
TLS_CERT_PATH=/etc/nginx/certs/fullchain.pem
TLS_KEY_PATH=/etc/nginx/certs/privkey.pem
TLS_MONITOR_CERT_PATH=/tls/fullchain.pem
BACKUP_RETENTION_DAYS=14
BACKUP_INTERVAL_SECONDS=86400
BACKUP_PATH=/backups
HSTS_ENABLED=False
HSTS_SECONDS=31536000
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=900
